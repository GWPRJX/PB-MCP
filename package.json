{
  "name": "pb-mcp",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "migrate:up": "migrate -path db/migrations -database \"$DATABASE_MIGRATION_URL\" up",
    "migrate:down": "migrate -path db/migrations -database \"$DATABASE_MIGRATION_URL\" down 1",
    "migrate:status": "migrate -path db/migrations -database \"$DATABASE_MIGRATION_URL\" version",
    "migrate:create": "migrate create -ext sql -dir db/migrations -seq",
    "test": "vitest run",
    "test:db": "vitest run --reporter=verbose tests/db/",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "latest",
    "typescript": "^5.0.0",
    "vitest": "latest"
  }
}
