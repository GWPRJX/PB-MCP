# Application database URL — uses app_login role (non-superuser, RLS enforced)
DATABASE_URL=postgres://app_login:changeme@localhost:5432/pb_mcp

# Migration database URL — uses postgres superuser role (DDL privileges)
# WARNING: Never use DATABASE_MIGRATION_URL in the running application
DATABASE_MIGRATION_URL=postgres://postgres:postgres@localhost:5432/pb_mcp

# Set to "true" to log a warning on startup if pending migrations are detected
MIGRATION_ALERT=true

NODE_ENV=development
PORT=3000

# Admin secret — protects all /admin/* endpoints and serves as the login password
# Generate with: openssl rand -hex 32
ADMIN_SECRET=changeme

# Admin login username (default: admin)
ADMIN_USERNAME=admin

# JWT secret for signing dashboard auth tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme

# JWT token lifetime in hours (default: 8)
JWT_EXPIRY_HOURS=8

# Dashboard origin for CORS — required when accessing from external IP or domain
# Set to the URL users will access the dashboard from (no trailing slash)
# Example: http://102.214.10.177 or https://mcp.yourdomain.com
# Omit in development to allow localhost:5173 and localhost:3001
DASHBOARD_ORIGIN=

# ERP credential encryption key — protects erp_app_secret and erp_password at rest
# 32-byte hex key: openssl rand -hex 32
ERP_ENCRYPTION_KEY=

# YouTrack KB Sync
# IMPORTANT: No trailing slash — the app appends /api/articles automatically
YOUTRACK_BASE_URL=https://your-instance.youtrack.cloud
YOUTRACK_TOKEN=perm-your-token-here
# Must match your actual YouTrack project short code (visible in article IDs like PROJ-123)
YOUTRACK_PROJECT=PROJ
# Sync interval in milliseconds (default: 30 minutes)
KB_SYNC_INTERVAL_MS=1800000

# Demo tenant ERP credentials (development only — auto-creates a "demo" tenant on startup)
# Set DEMO_ERP_BASE_URL to enable; omit to create tenant without ERP access
DEMO_ERP_BASE_URL=https://threadline.posibolt.com
DEMO_ERP_CLIENT_ID=your_client_id
DEMO_ERP_APP_SECRET=your_app_secret
DEMO_ERP_USERNAME=your_username
DEMO_ERP_PASSWORD=your_password
DEMO_ERP_TERMINAL=Terminal 1
