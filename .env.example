# Application database URL — uses app_login role (non-superuser, RLS enforced)
DATABASE_URL=postgres://app_login:changeme@localhost:5432/pb_mcp

# Migration database URL — uses postgres superuser role (DDL privileges)
# WARNING: Never use DATABASE_MIGRATION_URL in the running application
DATABASE_MIGRATION_URL=postgres://postgres:postgres@localhost:5432/pb_mcp

# Set to "true" to log a warning on startup if pending migrations are detected
MIGRATION_ALERT=true

NODE_ENV=development
PORT=3000

# Admin secret — protects all /admin/* endpoints and serves as the login password
# Generate with: openssl rand -hex 32
ADMIN_SECRET=changeme

# Admin login username (default: admin)
ADMIN_USERNAME=admin

# JWT secret for signing dashboard auth tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme

# JWT token lifetime in hours (default: 8)
JWT_EXPIRY_HOURS=8

# YouTrack KB Sync
YOUTRACK_BASE_URL=https://your-instance.youtrack.cloud
YOUTRACK_TOKEN=perm-your-token-here
YOUTRACK_PROJECT=P8
# Sync interval in milliseconds (default: 30 minutes)
KB_SYNC_INTERVAL_MS=1800000
